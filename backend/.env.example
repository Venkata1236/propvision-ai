# =========================
# APP CONFIG
# =========================
APP_NAME=PropVision AI
APP_VERSION=1.0.0
DEBUG=true

# =========================
# API CONFIG
# =========================
API_V1_PREFIX=/api/v1

# =========================
# OPENAI
# =========================
OPENAI_API_KEY=your_openai_api_key

# =========================
# OPENAI MODEL CONFIG
# =========================
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002

# =========================
# LANGSMITH OBSERVABILITY
# =========================
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=propvision-ai

# =========================
# DATABASE
# =========================
DATABASE_URL=postgresql+asyncpg://username:password@host:5432/database

# =========================
# MODEL PATHS
# =========================
XGB_MODEL_PATH=backend/saved_models/xgb_model.pkl
LGBM_MODEL_PATH=backend/saved_models/lgbm_model.pkl
META_MODEL_PATH=backend/saved_models/meta_model.pkl
PREPROCESSOR_PATH=backend/saved_models/preprocessor.pkl
FEATURE_NAMES_PATH=backend/saved_models/feature_names.json

# =========================
# SHAP
# =========================
SHAP_EXPLAINER_PATH=backend/saved_models/shap_explainer.pkl

# =========================
# FAISS
# =========================
FAISS_INDEX_PATH=backend/faiss_index/property_index.faiss
FAISS_METADATA_PATH=backend/faiss_index/metadata.pkl

# =========================
# RETRIEVAL
# =========================
TOP_K_COMPARABLES=3

# =========================
# CONFIDENCE INTERVAL
# =========================
CONFIDENCE_Z_SCORE=1.96

# =========================
# LOGGING
# =========================
LOG_LEVEL=INFO